# ---- Database ----
# Inside docker-compose, host is "db". For running the app on your Mac/PC
# directly against the dockerized DB, use localhost.
DATABASE_URL=postgresql://ems:ems_password@localhost:5432/ems

# ---- Gateway (i.MX93) ----
# Point at the REAL gateway. (For local dev with the fake gateway, start it with
# `docker compose --profile dev up -d` and set these to http://localhost:9000.)
GATEWAY_ID=imx93_gateway_1
GATEWAY_BASE_URL=https://ems-api.unityess.cloud
GATEWAY_LOG_BASE_URL=https://ems-api.unityess.cloud
# The NorthBound gateway requires auth. EITHER paste a static token here...
GATEWAY_API_TOKEN=
# ...OR (preferred) set gateway login credentials — the backend logs in and
# refreshes the token itself. For EMS command writes this account needs the
# gateway's internal_admin role.
GATEWAY_USERNAME=
GATEWAY_PASSWORD=

# ---- Ingestion behaviour ----
# Flush telemetry samples to DB when either threshold is hit.
INGEST_BATCH_SIZE=200
INGEST_FLUSH_SECONDS=2
# Reconnect backoff for the SSE stream (seconds).
SSE_RECONNECT_SECONDS=3
# Change-based storage: only write a historised field when it changes, or when
# this many seconds pass (heartbeat). Cuts rows for constant fields massively.
STORE_ON_CHANGE=true
STORE_HEARTBEAT_SECONDS=300
# Numeric must change by more than this to be stored (0 = any change, lossless).
NUMERIC_DEADBAND=0
# Set false to run the API without the background ingestion task
# (useful when a separate worker process owns ingestion).
INGEST_ENABLED=true

# ---- Auth (JWT) ----
# CHANGE this in production: openssl rand -hex 32
SECRET_KEY=dev-insecure-change-me-please-0123456789abcdef
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
# false = signup honours requested role (easy first setup).
# true  = signup always creates 'viewer' (production; promote via DB/admin).
LOCK_SIGNUP_ROLE=false

# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
